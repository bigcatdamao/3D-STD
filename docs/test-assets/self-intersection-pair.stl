solid self_intersection_pair
  facet normal 0 0 1
    outer loop
      vertex -20 -20 0
      vertex 20 -20 0
      vertex 0 20 0
    endloop
  endfacet
  facet normal 1 0 0
    outer loop
      vertex -6 -10 -12
      vertex -6 10 -12
      vertex -6 0 12
    endloop
  endfacet
  facet normal 1 0 0
    outer loop
      vertex 6 -10 -12
      vertex 6 10 -12
      vertex 6 0 12
    endloop
  endfacet
endsolid self_intersection_pair
