// Cloudflare Workers 配置(经 Git 集成由 Workers Builds 云端执行,本地无需 CLI)
{
  "name": "3d-std",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
  // T3 起在此追加:Durable Objects(配额账务)、KV(任务映射/熔断)、R2(生成结果转存)、Secrets(引擎 key)
}
